<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:desktop.app.ViewModels"
        xmlns:data="using:data.Entities"
        xmlns:desktop="using:desktop.app"
        xmlns:splot="using:ScottPlot.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="700"
        x:Class="desktop.app.Views.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="Heat Optimization - Production Units"
        Background="#f8fafc">

    <Window.Resources>
        <desktop:UriToBitmapConverter x:Key="UriToBitmapConverter" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.sidebar">
            <Setter Property="Height" Value="42" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#94a3b8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.sidebar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1e293b" />
        </Style>
        <Style Selector="Button.sidebar-active">
            <Setter Property="Height" Value="42" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#1e3a5f" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.icon-btn">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.icon-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#f1f5f9" />
        </Style>
        <Style Selector="TextBlock.th">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#64748b" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.td">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#1e293b" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="240,*" Background="#f8fafc">

        <!-- ═══════════════ SIDEBAR ═══════════════ -->
        <Border Grid.Column="0" Background="#0f172a">
            <Grid RowDefinitions="Auto,*,Auto">
                <Border Grid.Row="0" Padding="20,24,20,20" BorderBrush="#1e293b" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Background="#1d4ed8" CornerRadius="8" Width="32" Height="32">
                            <TextBlock Text="🔥" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="Heat Production" FontSize="13" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="Optimization MVP" FontSize="11" Foreground="#64748b" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1" Margin="12,16,12,16" Spacing="2">
                    <Button Classes="sidebar-active" Command="{Binding ShowCatalogCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="📊" FontSize="15" VerticalAlignment="Center" />
                            <TextBlock Text="Assets" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="sidebar" Command="{Binding ShowSourceDataCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="📈" FontSize="15" VerticalAlignment="Center" />
                            <TextBlock Text="Source Data" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="sidebar" Command="{Binding ShowScenariosCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="🧩" FontSize="15" VerticalAlignment="Center" />
                            <TextBlock Text="Scenarios" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="sidebar" Command="{Binding ShowRunOptimizationCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="▶" FontSize="15" VerticalAlignment="Center" />
                            <TextBlock Text="Run Optimization" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="sidebar" Command="{Binding ShowVisualizationCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="📉" FontSize="15" VerticalAlignment="Center" />
                            <TextBlock Text="Results &amp; Visualization" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="2" Padding="20,16" BorderBrush="#1e293b" BorderThickness="0,1,0,0">
                    <StackPanel Spacing="2">
                        <TextBlock Text="SDU / Danfoss Project" FontSize="11" Foreground="#475569" />
                        <TextBlock Text="Engineering MVP v1.0" FontSize="11" Foreground="#475569" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════ MAIN CONTENT ═══════════════ -->
        <Grid Grid.Column="1">

            <!-- ── CATALOG ── -->
            <Grid IsVisible="{Binding IsCatalogVisible}" Margin="32,28,32,28">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Asset Manager" FontSize="24" FontWeight="Bold" Foreground="#0f172a" />
                            <TextBlock Text="Manage production units for heat optimization. Configure technical parameters and costs."
                                       FontSize="13" Foreground="#64748b" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
                            <Button Height="38" Padding="14,0"
                                    Background="White" BorderBrush="#e2e8f0" BorderThickness="1"
                                    CornerRadius="8" Foreground="#374151" FontSize="13">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="↺" FontSize="15" VerticalAlignment="Center" />
                                    <TextBlock Text="Reset to Defaults" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Height="38" Padding="16,0"
                                    Background="#0f172a" BorderThickness="0" CornerRadius="8"
                                    Foreground="White" FontSize="13" FontWeight="SemiBold"
                                    Command="{Binding ShowCreateCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="+" FontSize="18" VerticalAlignment="Center" />
                                    <TextBlock Text="Add Unit" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Background="White" CornerRadius="12"
                            BorderBrush="#e2e8f0" BorderThickness="1">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0" Padding="20,14,20,14"
                                    BorderBrush="#f1f5f9" BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="56,100,120,110,150,120,110,100,80">
                                    <TextBlock Grid.Column="0" Classes="th" Text="" />
                                    <TextBlock Grid.Column="1" Classes="th" Text="NAME" />
                                    <TextBlock Grid.Column="2" Classes="th" Text="TYPE" />
                                    <TextBlock Grid.Column="3" Classes="th" Text="MAX HEAT (MW)" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="4" Classes="th" Text="MAX ELECTRICITY (MW)" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="5" Classes="th" Text="COST (DKK/MWH)" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="6" Classes="th" Text="CO₂ (KG/MWH)" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="7" Classes="th" Text="FUEL FACTOR" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="8" Classes="th" Text="ACTIONS" HorizontalAlignment="Center" />
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding FilteredProductionUnits}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="data:ProductionUnit">
                                            <Border Padding="20,0" BorderBrush="#f1f5f9" BorderThickness="0,0,0,1">
                                                <Grid ColumnDefinitions="56,100,120,110,150,120,110,100,80" Height="64">
                                                    <Border Grid.Column="0"
                                                            Width="40" Height="40"
                                                            CornerRadius="8"
                                                            ClipToBounds="True"
                                                            Background="#f1f5f9"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Left">
                                                        <Image Source="{Binding Data.ImageUrl, Converter={StaticResource UriToBitmapConverter}}"
                                                               Width="40" Height="40"
                                                               Stretch="UniformToFill" />
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding Data.Name}"
                                                               FontSize="14" FontWeight="SemiBold"
                                                               Foreground="#0f172a" VerticalAlignment="Center" />
                                                    <Border Grid.Column="2" VerticalAlignment="Center"
                                                            CornerRadius="20" Padding="10,4"
                                                            Background="#fef3c7" HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding Type}" FontSize="12" Foreground="#92400e" />
                                                    </Border>
                                                    <TextBlock Grid.Column="3" Classes="td"
                                                               Text="{Binding Data.MaxHeatMW, StringFormat='{}{0:0.0}'}"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Grid.Column="4" Classes="td"
                                                               Text="{Binding Data.ElectricityProducedMW, StringFormat='{}{0:0.0}'}"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Grid.Column="5" Classes="td"
                                                               Text="{Binding Data.ProductionCostPerMWh, StringFormat='{}{0:0}'}"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Grid.Column="6" Classes="td"
                                                               Text="{Binding Data.CO2KgPerMWh, StringFormat='{}{0:0}'}"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Grid.Column="7" Classes="td" Text="1.00" HorizontalAlignment="Right" />
                                                    <StackPanel Grid.Column="8" Orientation="Horizontal"
                                                                HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                                        <Button Classes="icon-btn"
                                                                Command="{Binding $parent[Window].DataContext.UpdateProductionUnitCommand}"
                                                                CommandParameter="{Binding}" ToolTip.Tip="Edit">
                                                            <TextBlock Text="✏" FontSize="15" Foreground="#64748b"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Button>
                                                        <Button Classes="icon-btn"
                                                                Command="{Binding $parent[Window].DataContext.DeleteProductionUnitCommand}"
                                                                CommandParameter="{Binding}" ToolTip.Tip="Delete">
                                                            <TextBlock Text="🗑" FontSize="15" Foreground="#ef4444"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ── CREATE (modal overlay) ── -->
            <Grid IsVisible="{Binding IsCreateVisible}">
                <Border Background="#80000000" />

                <!-- Modal card — scrollable so it fits all fields -->
                <Border Background="White" CornerRadius="12"
                        Width="500" MaxHeight="620"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        BoxShadow="0 20 60 0 #40000000">
                    <Grid RowDefinitions="Auto,*,Auto">

                        <!-- Modal header (fixed) -->
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto"
                              Margin="28,24,28,0">
                            <TextBlock Grid.Column="0" Text="Add Production Unit"
                                       FontSize="20" FontWeight="Bold" Foreground="#0f172a" />
                            <Button Grid.Column="1" Content="✕" Width="30" Height="30"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#94a3b8" FontSize="16"
                                    Command="{Binding ShowCatalogCommand}" />
                        </Grid>

                        <!-- Scrollable body -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      Margin="0,16,0,0">
                            <StackPanel Margin="28,0,28,0" Spacing="16">

                                <!-- Unit Name -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Unit Name" FontSize="13" FontWeight="SemiBold" Foreground="#374151" />
                                    <TextBox Text="{Binding NewUnitName, Mode=TwoWay}"
                                             Watermark="e.g., GB1" Height="40"
                                             Background="#f8fafc" BorderBrush="#e2e8f0" BorderThickness="1"
                                             CornerRadius="8" Padding="12,0" FontSize="14" />
                                </StackPanel>

                                <!-- Unit Type -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Unit Type" FontSize="13" FontWeight="SemiBold" Foreground="#374151" />
                                    <ComboBox ItemsSource="{Binding ProductionUnitTypes}"
                                              SelectedItem="{Binding SelectedProductionUnitType, Mode=TwoWay}"
                                              Height="40" HorizontalAlignment="Stretch"
                                              BorderBrush="#e2e8f0" BorderThickness="1"
                                              CornerRadius="8" FontSize="14" />
                                </StackPanel>

                                <!-- ══ IMAGE PICKER ══ -->
                                <StackPanel Spacing="8">
                                <TextBox Text="{Binding NewUnitImageUrl, Mode=TwoWay}" Watermark="Image URL" Height="36" />
                                </StackPanel>
                                <!-- ══ END IMAGE PICKER ══ -->

                                <!-- Max Heat + Max Electricity -->
                                <Grid ColumnDefinitions="*,12,*">
                                    <StackPanel Grid.Column="0" Spacing="6">
                                        <TextBlock Text="Max Heat (MW)" FontSize="13" FontWeight="SemiBold" Foreground="#374151" />
                                        <TextBox Text="{Binding NewUnitMaxHeatMW, Mode=TwoWay}"
                                                 Height="40" Background="#f8fafc"
                                                 BorderBrush="#e2e8f0" BorderThickness="1"
                                                 CornerRadius="8" Padding="12,0" FontSize="14" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="6">
                                        <TextBlock Text="Max Electricity (MW)" FontSize="13" FontWeight="SemiBold" Foreground="#374151" />
                                        <TextBox Watermark="0" Height="40" Background="#f8fafc"
                                                 BorderBrush="#e2e8f0" BorderThickness="1"
                                                 CornerRadius="8" Padding="12,0" FontSize="14" />
                                        <TextBlock Text="Positive = produces, Negative = consumes"
                                                   FontSize="11" Foreground="#94a3b8" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>

                                <!-- Cost + CO2 -->
                                <Grid ColumnDefinitions="*,12,*">
                                    <StackPanel Grid.Column="0" Spacing="6">
                                        <TextBlock Text="Cost (DKK/MWh)" FontSize="13" FontWeight="SemiBold" Foreground="#374151" />
                                        <TextBox Text="{Binding NewUnitProductionCostPerMWh, Mode=TwoWay}"
                                                 Height="40" Background="#f8fafc"
                                                 BorderBrush="#e2e8f0" BorderThickness="1"
                                                 CornerRadius="8" Padding="12,0" FontSize="14" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="6">
                                        <TextBlock Text="CO₂ (kg/MWh)" FontSize="13" FontWeight="SemiBold" Foreground="#374151" />
                                        <TextBox Text="{Binding NewUnitCO2KgPerMWh, Mode=TwoWay}"
                                                 Height="40" Background="#f8fafc"
                                                 BorderBrush="#e2e8f0" BorderThickness="1"
                                                 CornerRadius="8" Padding="12,0" FontSize="14" />
                                    </StackPanel>
                                </Grid>

                                <!-- Fuel Factor -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Fuel Factor" FontSize="13" FontWeight="SemiBold" Foreground="#374151" />
                                    <TextBox Watermark="1.0" Height="40"
                                             Background="#f8fafc" BorderBrush="#e2e8f0" BorderThickness="1"
                                             CornerRadius="8" Padding="12,0" FontSize="14" />
                                    <TextBlock Text="MWh fuel consumed per MWh heat produced"
                                               FontSize="11" Foreground="#94a3b8" />
                                </StackPanel>

                                <TextBlock Text="{Binding DebugMessage}" Foreground="#ef4444" FontSize="11"
                                           IsVisible="{Binding DebugMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                                <!-- Spacer at bottom of scroll -->
                                <Border Height="8" />
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer buttons (fixed) -->
                        <Grid Grid.Row="2" ColumnDefinitions="*,12,*" Margin="28,12,28,24">
                            <Button Grid.Column="0" Content="Cancel" Height="40"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Background="White" BorderBrush="#e2e8f0" BorderThickness="1"
                                    Foreground="#374151" FontSize="14" CornerRadius="8"
                                    Command="{Binding ShowCatalogCommand}" />
                            <Button Grid.Column="2" Content="Add Unit" Height="40"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Background="#0f172a" BorderThickness="0"
                                    Foreground="White" FontSize="14" FontWeight="SemiBold" CornerRadius="8"
                                    Command="{Binding AddProductionUnitCommand}" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── SOURCE DATA ── -->
            <Grid IsVisible="{Binding IsSourceDataVisible}" Margin="32,28,32,28">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,16">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Source Data Manager" FontSize="24" FontWeight="Bold" Foreground="#0f172a" />
                            <TextBlock Text="Upload, generate and manage time series datasets for heat demand and electricity prices."
                                       FontSize="13" Foreground="#64748b" Margin="0,4,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1" Height="38" Margin="8,0,0,0" Padding="14,0"
                                Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="8"
                                Foreground="#1e293b" FontSize="13"
                                Command="{Binding GenerateWinterSampleCommand}"
                                Content="Generate Winter Sample" />
                        <Button Grid.Column="2" Height="38" Margin="8,0,0,0" Padding="14,0"
                                Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="8"
                                Foreground="#1e293b" FontSize="13"
                                Command="{Binding GenerateSummerSampleCommand}"
                                Content="Generate Summer Sample" />
                        <Button Grid.Column="3" Height="38" Margin="8,0,0,0" Padding="14,0"
                                Background="#0f172a" BorderThickness="0" CornerRadius="8"
                                Foreground="White" FontSize="13" FontWeight="SemiBold"
                                Click="UploadCsvButton_Click"
                                Content="Upload CSV" />
                    </Grid>

                    <Border Grid.Row="1" Background="#fff7ed" BorderBrush="#fdba74" BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="CSV Format Requirements" FontWeight="SemiBold" Foreground="#9a3412" FontSize="13" />
                            <TextBlock Text="Columns required: timestamp, heat_demand, electricity_price. Rows must be hourly and consecutive."
                                       Foreground="#9a3412" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Background="#eff6ff" BorderBrush="#bfdbfe" BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,0,12">
                        <TextBlock Text="{Binding SourceDataStatusMessage}" Foreground="#1e3a8a" FontSize="12" TextWrapping="Wrap" />
                    </Border>

                    <Border Grid.Row="3" Background="#fef2f2" BorderBrush="#fecaca" BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,0,12"
                            IsVisible="{Binding HasSourceDataValidationMessage}">
                        <TextBlock Text="{Binding SourceDataValidationMessage}" Foreground="#991b1b" FontSize="12" TextWrapping="Wrap" />
                    </Border>

                    <Border Grid.Row="4" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Margin="0,0,0,12">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0" Padding="16,12" BorderBrush="#f1f5f9" BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="260,100,80,240,130,70">
                                    <TextBlock Grid.Column="0" Classes="th" Text="DATASET NAME" />
                                    <TextBlock Grid.Column="1" Classes="th" Text="PERIOD" />
                                    <TextBlock Grid.Column="2" Classes="th" Text="HOURS" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="3" Classes="th" Text="DATE RANGE" />
                                    <TextBlock Grid.Column="4" Classes="th" Text="UPLOADED" />
                                    <TextBlock Grid.Column="5" Classes="th" Text="ACTIONS" HorizontalAlignment="Center" />
                                </Grid>
                            </Border>
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding SourceDatasets}"
                                     SelectedItem="{Binding SelectedSourceDataset, Mode=TwoWay}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     MaxHeight="220">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="16,0" BorderBrush="#f1f5f9" BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="260,100,80,240,130,70" Height="52">
                                                <TextBlock Grid.Column="0" Classes="td" Text="{Binding DatasetName}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Classes="td" Text="{Binding Period}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2" Classes="td" Text="{Binding Hours}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Classes="td" Text="{Binding DateRange}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="4" Classes="td" Text="{Binding Uploaded, StringFormat='{}{0:MMM d HH:mm}'}" VerticalAlignment="Center" />
                                                <Button Grid.Column="5" Classes="icon-btn"
                                                        Command="{Binding $parent[Window].DataContext.DeleteSourceDatasetCommand}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="🗑" Foreground="#ef4444" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Row="5" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0" Padding="16,12" BorderBrush="#f1f5f9" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="Dataset Details" FontSize="14" FontWeight="SemiBold" Foreground="#0f172a" />
                                    <TextBlock Text="{Binding SelectedDatasetDateRange}" FontSize="12" Foreground="#64748b" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="16,12,16,16">
                                <Grid Grid.Row="0" ColumnDefinitions="220,160,160" Margin="0,0,0,8">
                                    <TextBlock Grid.Column="0" Classes="th" Text="TIMESTAMP" />
                                    <TextBlock Grid.Column="1" Classes="th" Text="HEAT DEMAND" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="2" Classes="th" Text="ELECTRICITY PRICE" HorizontalAlignment="Right" />
                                </Grid>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="240">
                                    <ItemsControl ItemsSource="{Binding SelectedDatasetRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Height="32">
                                                    <Grid ColumnDefinitions="220,160,160">
                                                        <TextBlock Grid.Column="0" Classes="td" Text="{Binding TimestampUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="1" Classes="td" Text="{Binding HeatDemand}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="2" Classes="td" Text="{Binding ElectricityPrice}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ── SCENARIOS ── -->
            <Grid IsVisible="{Binding IsScenariosVisible}" Margin="32,28,32,28">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Scenarios" FontSize="24" FontWeight="Bold" Foreground="#0f172a" />
                        <TextBlock Foreground="#64748b" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Text="Two pre-defined optimization scenarios. Scenario 1 uses three gas boilers + one oil boiler (heat only). Scenario 2 uses two gas boilers + gas motor (CHP) + electric boiler (electricity-consuming)." />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1">
                        <StackPanel Spacing="16">
                            <!-- Scenario 1 card -->
                            <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="24">
                                <StackPanel Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border Background="#dbeafe" CornerRadius="6" Padding="8,4">
                                            <TextBlock Text="Scenario 1" FontWeight="Bold" Foreground="#1e40af" FontSize="14" />
                                        </Border>
                                        <TextBlock Text="Heat-Only Boilers (Winter)" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#0f172a" />
                                    </StackPanel>
                                    <TextBlock TextWrapping="Wrap" Foreground="#374151" FontSize="13"
                                               Text="Units: GB1 (510 DKK/MWh), GB2 (540 DKK/MWh), GB3 (580 DKK/MWh), OB1 (690 DKK/MWh). All boilers are heat-only with fixed costs. Dispatch order is always cheapest first. GB2 is placed under maintenance for hours 48-96." />
                                    <Grid ColumnDefinitions="*,*,*,*" Margin="0,8,0,0">
                                        <Border Grid.Column="0" Background="#f0fdf4" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="GB1" FontWeight="Bold" Foreground="#166534" />
                                                <TextBlock Text="3 MW heat" FontSize="12" Foreground="#166534" />
                                                <TextBlock Text="510 DKK/MWh" FontSize="12" Foreground="#166534" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Background="#f0fdf4" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="GB2" FontWeight="Bold" Foreground="#166534" />
                                                <TextBlock Text="2 MW heat" FontSize="12" Foreground="#166534" />
                                                <TextBlock Text="540 DKK/MWh" FontSize="12" Foreground="#166534" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="2" Background="#f0fdf4" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="GB3" FontWeight="Bold" Foreground="#166534" />
                                                <TextBlock Text="4 MW heat" FontSize="12" Foreground="#166534" />
                                                <TextBlock Text="580 DKK/MWh" FontSize="12" Foreground="#166534" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="3" Background="#fef3c7" CornerRadius="8" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="OB1 (Peak)" FontWeight="Bold" Foreground="#92400e" />
                                                <TextBlock Text="6 MW heat" FontSize="12" Foreground="#92400e" />
                                                <TextBlock Text="690 DKK/MWh" FontSize="12" Foreground="#92400e" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <Border Background="#fef2f2" CornerRadius="8" Padding="10" Margin="0,4,0,0">
                                        <TextBlock Text="⚠ GB2 under maintenance: hours 48–96 (2 days)" Foreground="#991b1b" FontSize="12" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Scenario 2 card -->
                            <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="24">
                                <StackPanel Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border Background="#ede9fe" CornerRadius="6" Padding="8,4">
                                            <TextBlock Text="Scenario 2" FontWeight="Bold" Foreground="#5b21b6" FontSize="14" />
                                        </Border>
                                        <TextBlock Text="CHP + Electric Boiler (Summer, Electricity Prices)" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#0f172a" />
                                    </StackPanel>
                                    <TextBlock TextWrapping="Wrap" Foreground="#374151" FontSize="13"
                                               Text="Units: GB1, GB2, GM1 (CHP – produces electricity), EB1 (consumes electricity). Net production costs depend on real-time electricity prices. GM1 is profitable when electricity prices are high; EB1 is profitable when electricity prices are low or negative. GM1 under maintenance for hours 48-96." />
                                    <Grid ColumnDefinitions="*,*,*,*" Margin="0,8,0,0">
                                        <Border Grid.Column="0" Background="#f0fdf4" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="GB1" FontWeight="Bold" Foreground="#166534" />
                                                <TextBlock Text="3 MW heat" FontSize="12" Foreground="#166534" />
                                                <TextBlock Text="510 DKK/MWh" FontSize="12" Foreground="#166534" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Background="#f0fdf4" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="GB2" FontWeight="Bold" Foreground="#166534" />
                                                <TextBlock Text="2 MW heat" FontSize="12" Foreground="#166534" />
                                                <TextBlock Text="540 DKK/MWh" FontSize="12" Foreground="#166534" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="2" Background="#dbeafe" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="GM1 (CHP)" FontWeight="Bold" Foreground="#1e40af" />
                                                <TextBlock Text="5.3 MW heat + 3.9 MW elec" FontSize="12" Foreground="#1e40af" />
                                                <TextBlock Text="975 – elec income DKK/MWh" FontSize="12" Foreground="#1e40af" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="3" Background="#fce7f3" CornerRadius="8" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="EB1 (Electric)" FontWeight="Bold" Foreground="#9d174d" />
                                                <TextBlock Text="6 MW heat" FontSize="12" Foreground="#9d174d" />
                                                <TextBlock Text="15 + elec cost DKK/MWh" FontSize="12" Foreground="#9d174d" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <Border Background="#fef2f2" CornerRadius="8" Padding="10" Margin="0,4,0,0">
                                        <TextBlock Text="⚠ GM1 under maintenance: hours 48–96 (2 days)" Foreground="#991b1b" FontSize="12" />
                                    </Border>
                                    <Border Background="#eff6ff" CornerRadius="8" Padding="10">
                                        <TextBlock TextWrapping="Wrap" Foreground="#1e40af" FontSize="12"
                                                   Text="ℹ Note: Negative electricity prices cause GM1 net cost to exceed its base cost. During those hours EB1 becomes the cheapest option and provides extra income from electricity consumption." />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ── RUN OPTIMIZATION ── -->
            <Grid IsVisible="{Binding IsRunOptimizationVisible}" Margin="32,28,32,28">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Run Optimization" FontSize="24" FontWeight="Bold" Foreground="#0f172a" />
                        <TextBlock Text="Select a season and run the optimizer. Results are saved and available in Results &amp; Visualization."
                                   FontSize="13" Foreground="#64748b" Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Controls -->
                    <Border Grid.Row="1" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,16">
                        <Grid ColumnDefinitions="Auto,16,200,24,Auto,16,Auto" VerticalAlignment="Center">
                            <TextBlock Grid.Column="0" Text="Season:" FontSize="14" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding SeasonOptions}"
                                      SelectedItem="{Binding SelectedSeason, Mode=TwoWay}"
                                      Height="40" HorizontalAlignment="Stretch"
                                      BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="8" FontSize="14" />
                            <Button Grid.Column="4"
                                    Height="40" Padding="20,0"
                                    Background="#0f172a" BorderThickness="0" CornerRadius="8"
                                    Foreground="White" FontSize="14" FontWeight="SemiBold"
                                    Command="{Binding RunOptimizationCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="▶" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Run" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="6"
                                    Height="40" Padding="16,0"
                                    Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="8"
                                    Foreground="#374151" FontSize="14"
                                    Command="{Binding LoadOptimizationRunsCommand}">
                                <TextBlock Text="⟳ Load History" VerticalAlignment="Center" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Status -->
                    <Border Grid.Row="2" Background="#eff6ff" BorderBrush="#bfdbfe" BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,0,0,16">
                        <TextBlock Text="{Binding OptimizationStatusMessage}" Foreground="#1e3a8a" FontSize="13" TextWrapping="Wrap" />
                    </Border>

                    <!-- Run history table -->
                    <Border Grid.Row="3" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0" Padding="20,14" BorderBrush="#f1f5f9" BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="60,160,100,140,130,130,140,*">
                                    <TextBlock Grid.Column="0" Classes="th" Text="ID" />
                                    <TextBlock Grid.Column="1" Classes="th" Text="CREATED" />
                                    <TextBlock Grid.Column="2" Classes="th" Text="SEASON / SOURCE" />
                                    <TextBlock Grid.Column="3" Classes="th" Text="PERIOD FROM" />
                                    <TextBlock Grid.Column="4" Classes="th" Text="TOTAL COST (DKK)" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="5" Classes="th" Text="ELEC CASHFLOW" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="6" Classes="th" Text="TOTAL CO₂ (KG)" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="7" Classes="th" Text="ACTION" HorizontalAlignment="Center" />
                                </Grid>
                            </Border>
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding OptimizationRuns}"
                                     SelectedItem="{Binding SelectedOptimizationRun, Mode=TwoWay}"
                                     BorderThickness="0" Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="20,0" BorderBrush="#f1f5f9" BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="60,160,100,140,130,130,140,*" Height="52">
                                                <TextBlock Grid.Column="0" Classes="td" Text="{Binding Id}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Classes="td" Text="{Binding CreatedAtUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2" Classes="td" Text="{Binding ElectricityPriceSource}" VerticalAlignment="Center" FontSize="11" />
                                                <TextBlock Grid.Column="3" Classes="td" Text="{Binding TimeFromUtc, StringFormat='{}{0:yyyy-MM-dd}'}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="4" Classes="td" Text="{Binding TotalNetCostDkk, StringFormat='{}{0:N0}'}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="5" Classes="td" Text="{Binding TotalElectricityCashflowDkk, StringFormat='{}{0:N0}'}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="6" Classes="td" Text="{Binding TotalCo2Kg, StringFormat='{}{0:N0}'}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                <Button Grid.Column="7"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Height="30" Padding="12,0"
                                                        Background="#0f172a" BorderThickness="0" CornerRadius="6"
                                                        Foreground="White" FontSize="12"
                                                        Command="{Binding $parent[Window].DataContext.ShowVisualizationCommand}">
                                                    <TextBlock Text="View Charts" VerticalAlignment="Center" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ── VISUALIZATION ── -->
            <Grid IsVisible="{Binding IsVisualizationVisible}" Margin="32,28,32,28">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Results &amp; Visualization" FontSize="24" FontWeight="Bold" Foreground="#0f172a" />
                        <TextBlock Text="Charts for the selected optimization run. Switch runs from the Run Optimization view."
                                   FontSize="13" Foreground="#64748b" Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- No run selected placeholder -->
                    <Border Grid.Row="1"
                            IsVisible="{Binding !HasCharts}"
                            Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                            <TextBlock Text="📉" FontSize="48" HorizontalAlignment="Center" />
                            <TextBlock Text="No optimization run selected." FontSize="16" Foreground="#64748b" HorizontalAlignment="Center" />
                            <TextBlock Text="Go to Run Optimization, run or select a result, then come back here." FontSize="13" Foreground="#94a3b8" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  IsVisible="{Binding HasCharts}">
                        <StackPanel Spacing="20">
                            <!-- Summary row -->
                            <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="20">
                                <Grid ColumnDefinitions="*,*,*,*">
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock Text="Run ID" FontSize="11" Foreground="#64748b" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding SelectedOptimizationRun.Id}" FontSize="22" FontWeight="Bold" Foreground="#0f172a" HorizontalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="Total Net Cost (DKK)" FontSize="11" Foreground="#64748b" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding SelectedOptimizationRun.TotalNetCostDkk, StringFormat='{}{0:N0}'}" FontSize="22" FontWeight="Bold" Foreground="#1e40af" HorizontalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="Electricity Cashflow (DKK)" FontSize="11" Foreground="#64748b" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding SelectedOptimizationRun.TotalElectricityCashflowDkk, StringFormat='{}{0:N0}'}" FontSize="22" FontWeight="Bold" Foreground="#166534" HorizontalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                        <TextBlock Text="Total CO₂ (kg)" FontSize="11" Foreground="#64748b" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding SelectedOptimizationRun.TotalCo2Kg, StringFormat='{}{0:N0}'}" FontSize="22" FontWeight="Bold" Foreground="#9a3412" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Heat production chart -->
                            <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="16">
                                <splot:AvaPlot x:Name="HeatProductionAvaPlot" Height="280" />
                            </Border>

                            <!-- Electricity chart -->
                            <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="16">
                                <splot:AvaPlot x:Name="ElectricityAvaPlot" Height="280" />
                            </Border>

                            <!-- Cost & cashflow chart -->
                            <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="16">
                                <splot:AvaPlot x:Name="CostAvaPlot" Height="280" />
                            </Border>

                            <!-- CO2 chart -->
                            <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="16">
                                <splot:AvaPlot x:Name="Co2AvaPlot" Height="280" />
                            </Border>

                            <!-- Net production cost comparison chart -->
                            <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="16">
                                <splot:AvaPlot x:Name="NetProductionCostAvaPlot" Height="280" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Loading overlay -->
            <Border IsVisible="{Binding IsLoading}" Background="#80ffffff">
                <TextBlock Text="Loading..." FontSize="18" FontWeight="SemiBold"
                           Foreground="#0f172a" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
        </Grid>
    </Grid>
</Window>
