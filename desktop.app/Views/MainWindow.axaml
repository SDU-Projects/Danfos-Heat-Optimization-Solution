<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:desktop.app.ViewModels"
        xmlns:data="using:data.Entities"
        xmlns:desktop="using:desktop.app"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="desktop.app.Views.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="Heat Optimization - Production Units">

    <Window.Resources>
        <desktop:UriToBitmapConverter x:Key="UriToBitmapConverter" />
    </Window.Resources>

    <Grid ColumnDefinitions="240,*" Background="#f4f6f8">

        <StackPanel Grid.Column="0" Background="#2f3d4f" Margin="16" Spacing="10">
            <Button Content="📋 Catalog" Height="45" Command="{Binding ShowCatalogCommand}" Background="#1f78d1" Foreground="White" BorderThickness="0" />
            <Button Content="➕ Create" Height="45" Command="{Binding ShowCreateCommand}" Background="#27ae60" Foreground="White" BorderThickness="0" />
            <Button Content="🔄 Refresh" Height="45" Command="{Binding RefreshCatalogCommand}" Background="#4a90e2" Foreground="White" BorderThickness="0" />
        </StackPanel>

        <Grid Grid.Column="1" Margin="20">

            <Grid IsVisible="{Binding IsCatalogVisible}">
                <StackPanel>
                    <TextBlock Text="Production Units Catalog" FontSize="24" FontWeight="Bold" Foreground="#2f3d4f" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Height="520">
                        <ItemsControl ItemsSource="{Binding FilteredProductionUnits}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="data:ProductionUnit">
                                    <Border Background="White" CornerRadius="8" BorderBrush="#d0d7e0" BorderThickness="1" Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="100,*,130" RowDefinitions="Auto,Auto,Auto,Auto">
                                            <Image Source="{Binding Data.ImageUrl, Converter={StaticResource UriToBitmapConverter}}" Width="100" Height="100" Stretch="Uniform" Grid.Column="0" Grid.RowSpan="4" Margin="0,0,12,0" />
                                            <TextBlock Text="{Binding Data.Name}" FontSize="18" FontWeight="Bold" Grid.Column="1" />
                                            <TextBlock Text="{Binding Id, StringFormat='ID: {0}'}" FontSize="12" Foreground="#586673" Grid.Column="2" HorizontalAlignment="Right" />

                                            <TextBlock Text="{Binding Type, StringFormat='Tipo: {0}'}" Grid.Row="1" Grid.Column="1" Foreground="#5f6f85" />
                                            <TextBlock Text="{Binding Data.MaxHeatMW, StringFormat='MaxHeatMW: {0}'}" Grid.Row="2" Grid.Column="1" Foreground="#5f6f85" />
                                            <TextBlock Text="{Binding Data.ProductionCostPerMWh, StringFormat='Coste: {0} €/MWh'}" Grid.Row="3" Grid.Column="1" Foreground="#5f6f85" />

                                            <StackPanel Grid.Row="0" Grid.RowSpan="4" Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="6">
                                                <Button Content="Save" Width="110" Height="30" Background="#27ae60" Foreground="White" Command="{Binding $parent[Window].DataContext.UpdateProductionUnitCommand}" CommandParameter="{Binding}" />
                                                <Button Content="Delete" Width="110" Height="30" Background="#e74c3c" Foreground="White" Command="{Binding $parent[Window].DataContext.DeleteProductionUnitCommand}" CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Grid>

            <Grid IsVisible="{Binding IsCreateVisible}">
                <StackPanel Width="600" Spacing="12">
                    <TextBlock Text="Create Production Unit" FontSize="24" FontWeight="Bold" Foreground="#2f3d4f" />
                    <TextBox Text="{Binding NewUnitName, Mode=TwoWay}" Watermark="Name" Height="36" />
                    <TextBox Text="{Binding NewUnitImageUrl, Mode=TwoWay}" Watermark="Image URL" Height="36" />
                    <TextBox Text="{Binding NewUnitMaxHeatMW, Mode=TwoWay}" Watermark="MaxHeatMW" Height="36" />
                    <TextBox Text="{Binding NewUnitProductionCostPerMWh, Mode=TwoWay}" Watermark="ProductionCostPerMWh" Height="36" />
                    <TextBox Text="{Binding NewUnitCO2KgPerMWh, Mode=TwoWay}" Watermark="CO2KgPerMWh" Height="36" />
                    <ComboBox ItemsSource="{Binding ProductionUnitTypes}" SelectedItem="{Binding SelectedProductionUnitType, Mode=TwoWay}" Height="36" />
                    <TextBlock Text="{Binding DebugMessage}" Foreground="Red" FontSize="12" />
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                        <Button Content="Create" Width="120" Height="36" Background="#27ae60" Foreground="White" Command="{Binding AddProductionUnitCommand}" />
                        <Button Content="Cancel " Width="120" Height="36" Background="#7f8c8d" Foreground="White" Command="{Binding ShowCatalogCommand}" />
                    </StackPanel>
                </StackPanel>
            </Grid>

        </Grid>

    </Grid>
</Window>
